# Copy this file to docker/.env and fill in the values
# docker/.env is gitignored — never commit secrets

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=arteci

# API
API_PORT=3001

# SigNoz Cloud ingestion key (provided separately)
SIGNOZ_INGESTION_KEY=
