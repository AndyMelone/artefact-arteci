# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=arteci
MINIO_USE_SSL=false

# API
API_PORT=3001
API_IMAGE_TAG=latest

# SigNoz Cloud : ingest.us2.signoz.cloud:443
# SigNoz self-hosted (Option A) : localhost:4317
# SigNoz self-hosted (Docker Compose) : signoz-ingester:4317
# SigNoz self-hosted (Kubernetes) : http://signoz-otel-collector.monitoring.svc.cluster.local:4317
# Go local sans SigNoz : laisser vide (désactivé)
OTEL_EXPORTER_OTLP_ENDPOINT=signoz-ingester:4317
OTEL_SERVICE_NAME=arteci-api-go
SIGNOZ_INGESTION_KEY=

# SigNoz self-hosted — Kubernetes uniquement 
# SIGNOZ_POSTGRES_PASSWORD=Arteci-Postgres-2026!
# SIGNOZ_JWT_SECRET=Arteci-Jwt-Secret-Key-2026-Local!
# SIGNOZ_ROOT_EMAIL=admin@arteci.local
# SIGNOZ_ROOT_PASSWORD=Arteci-Signoz-Admin-2026
# SIGNOZ_ROOT_ORG_NAME=arteci
