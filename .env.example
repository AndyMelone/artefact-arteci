# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=arteci
MINIO_USE_SSL=false

# API
API_PORT=3001

# SigNoz Cloud : ingest.us2.signoz.cloud:443
# SigNoz self-hosted (Docker) : signoz-ingester:4317
# Go local sans SigNoz : laisser vide (désactivé)
OTEL_EXPORTER_OTLP_ENDPOINT=ingest.us2.signoz.cloud:443
OTEL_SERVICE_NAME=arteci-api-go
SIGNOZ_INGESTION_KEY=

# SigNoz self-hosted (Kubernetes uniquement — Helm) — jamais commité en dur,
# injecté dans helm-values.yaml via deploy-k8s.sh --set-string
SIGNOZ_POSTGRES_PASSWORD=signoz
SIGNOZ_JWT_SECRET=change-me-32-chars-minimum-please
SIGNOZ_ROOT_EMAIL=admin@arteci.local
# >=12 car., 1 maj., 1 min., 1 chiffre, 1 symbole (règle SigNoz)
SIGNOZ_ROOT_PASSWORD=Change-Me-2026!
SIGNOZ_ROOT_ORG_NAME=arteci